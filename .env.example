# These defaults are for LOCAL sandbox dev. For production values (real Whop key,
# PAYOUTS_ENABLED=true, a set CRON_SECRET, cloud Supabase, and enabling Supabase
# email confirmations) see DEPLOY.md.

# ---- Whop ----
# Server-side only. NEVER expose in the browser / NEXT_PUBLIC_*.
# Create a SANDBOX key at https://sandbox.whop.com/dashboard/developer
WHOP_API_KEY=apik_your_sandbox_key_here

# Base URL. Sandbox by default; set to https://api.whop.com/api/v1 for production.
WHOP_BASE_URL=https://sandbox-api.whop.com/api/v1

# Pin the Beta API version so response shapes stay stable.
WHOP_API_VERSION_DATE=2026-07-01

# Base64 webhook signing secret from the Whop dashboard (Chunk 5).
# Standard Webhooks format; the SDK verifies with it via webhooks.unwrap().
WHOP_WEBHOOK_SECRET=

# Protects the reconciliation cron (/api/cron). Vercel Cron sends it as a Bearer
# token. Leave unset in local dev to allow the endpoint.
CRON_SECRET=

# Platform (parent) company id — your CreatorJobs sandbox business (biz_…).
WHOP_PLATFORM_COMPANY_ID=biz_your_platform_company

# Public base URL for Whop redirect links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payouts (Chunk 6). false = stub releases (sandbox); true = real Whop transfers.
PAYOUTS_ENABLED=false
# Reserve/hold window (seconds) before releasing a seller payout.
PAYOUT_RESERVE_SECONDS=60

# ---- Supabase (Chunk 1) ----
# From your Supabase project settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-side only. Bypasses RLS — used by the ops dashboard + webhook worker.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Ops dashboard (/admin) allowlist (comma-separated emails).
ADMIN_EMAILS=you@example.com

# ---- Observability ----
# Structured JSON logs are emitted on stdout/stderr for the money paths (webhooks,
# orders, payouts, cron) — ingest them via Vercel log drains / Datadog / etc.
# Level gate: debug | info | warn | error (default info).
LOG_LEVEL=info
